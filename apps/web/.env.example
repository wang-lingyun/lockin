# Copy to apps/web/.env.local and fill in from your Supabase project
# (Supabase dashboard → Project Settings → API). Never commit .env.local.

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used in later stages (admin/command layer). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Stage 8 — agent gateway signing secret. Keep secret.
AGENT_GATEWAY_SIGNING_SECRET=
